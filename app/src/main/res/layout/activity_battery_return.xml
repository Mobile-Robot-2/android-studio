<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout" android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_animated_sunset"> <com.google.android.material.card.MaterialCardView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#CC161824" app:cardCornerRadius="40dp" app:cardElevation="16dp" app:strokeColor="#4DFFFFFF" app:strokeWidth="2dp"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="64dp"> <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieBattery"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginBottom="32dp"
        app:lottie_rawRes="@raw/charging"
        app:lottie_autoPlay="true"
        app:lottie_loop="true" />

        <TextView
            android:id="@+id/tvWarningTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="배터리가 부족합니다"
            android:textColor="#FFD54F" android:textSize="56sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvWarningSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="충전을 위해 홈 베이스로 복귀합니다.\n안전을 위해 로봇의 이동 경로를 비켜주세요."
            android:textAlignment="center"
            android:textColor="#E0E0E0" android:textSize="32sp"
            android:lineSpacingExtra="12dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>