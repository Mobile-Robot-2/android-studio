<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout" android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_animated_sunset"> <TextView
    android:id="@+id/tvMessage"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:text="💊 복약하실 시간입니다 💊\n\n약을 드셨다면 복약 완료 버튼을 눌러주세요."
    android:textAlignment="center"
    android:textColor="#81C784"
    android:textSize="48sp"
    android:textStyle="bold"
    android:lineSpacingExtra="12dp"
    app:layout_constraintWidth_percent="0.85"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintBottom_toTopOf="@+id/tvTimer"
    app:layout_constraintVertical_chainStyle="packed"
    android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="60초 후 보호자에게 연락합니다."
        android:textColor="#E57373"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/tvMessage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/btnMedicationDone"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnMedicationDone"
        android:layout_width="480dp"
        android:layout_height="120dp"
        android:text="✔️ 복약 완료"
        android:textColor="#81C784"
        android:textSize="36sp"
        android:textStyle="bold"
        android:backgroundTint="#CC161824" android:elevation="12dp" app:strokeWidth="2dp"
        app:strokeColor="#4DFFFFFF" app:cornerRadius="24dp"
        app:layout_constraintTop_toBottomOf="@+id/tvTimer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>