<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout" android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_animated_sunset"> <com.google.android.material.card.MaterialCardView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="600dp" app:cardBackgroundColor="#CC161824"
    app:cardCornerRadius="40dp"
    app:cardElevation="16dp"
    app:strokeColor="#4DFFFFFF"
    app:strokeWidth="2dp"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="56dp"> <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="게임을 준비하고 있어요!"
        android:textSize="40sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/tvCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10"
            android:textSize="120sp"
            android:textColor="#FFD54F" android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <TextView
            android:id="@+id/tvCheckLog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="350dp" android:text=""
            android:textSize="26sp"
            android:textColor="#BDBDBD"
            android:lineSpacingExtra="10dp"
            android:gravity="start" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>