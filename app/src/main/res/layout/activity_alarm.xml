<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#15171E">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏰ 리듬 게임 시간입니다 ⏰\n\n운동을 시작하시겠습니까?"
        android:textAlignment="center"
        android:textColor="#FFB74D"
        android:textSize="48sp"
        android:textStyle="bold"
        android:lineSpacingExtra="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tvTimer"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="60초 후 대기 장소로 복귀합니다."
        android:textColor="#E57373"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/btnDismiss"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnDismiss"
        android:layout_width="480dp"
        android:layout_height="120dp"
        android:text="▶️ 게임 시작하기"
        android:textColor="#FFB74D"
        android:textSize="36sp"
        android:textStyle="bold"
        android:backgroundTint="#20232E"
        app:strokeWidth="2dp"
        app:strokeColor="#FFB74D"
        app:cornerRadius="24dp"
        app:layout_constraintTop_toBottomOf="@+id/tvTimer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>