<?xml version="1.0" encoding="utf-8"?>
<animation-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:oneshot="false">

    <!-- 1. 다크 네이비 -> 채도 낮은 더스티 로즈 -->
    <item android:duration="5000">
        <shape android:shape="rectangle">
            <gradient android:startColor="#11131A" android:endColor="#7A5255" android:angle="270"/>
        </shape>
    </item>

    <!-- 2. 약간 더 밝은 네이비 -> 딥 코퍼(구리색) -->
    <item android:duration="5000">
        <shape android:shape="rectangle">
            <gradient android:startColor="#161824" android:endColor="#8C5A58" android:angle="315"/>
        </shape>
    </item>

    <!-- 3. 미드나잇 블루 -> 뮤트 톤의 웜 오렌지 -->
    <item android:duration="5000">
        <shape android:shape="rectangle">
            <gradient android:startColor="#0D0E15" android:endColor="#6E4845" android:angle="225"/>
        </shape>
    </item>
</animation-list>